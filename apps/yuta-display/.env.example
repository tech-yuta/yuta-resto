# DATABASE_URL — password must be URL-encoded if it contains special characters.
# Special chars: @ → %40  ! → %21  # → %23  $ → %24  % → %25  : → %3A
# Encode: node -e "console.log(encodeURIComponent('your_password'))"
DATABASE_URL=postgres://yuta:change_me@db:5432/luna_display

# POSTGRES_PASSWORD — raw password for the Postgres container (no URL encoding needed)
POSTGRES_PASSWORD=change_me

# Optional — defaults to ./public/uploads/display when unset
UPLOAD_DIR=
