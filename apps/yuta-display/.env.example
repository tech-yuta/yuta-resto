# DATABASE_URL points to the existing production PostgreSQL instance.
# Password must be URL-encoded if it contains special characters.
# Examples: @ -> %40  ! -> %21  # -> %23  $ -> %24  % -> %25  : -> %3A
# Encode: node -e "console.log(encodeURIComponent('your_password'))"
DATABASE_URL=postgres://yuta:change_me@luna-postgres:5432/luna_display

# Docker network where the existing PostgreSQL container is attached.
POSTGRES_NETWORK=postgres_default

# Optional outside Docker.
# Docker Compose sets this to the mounted uploads volume path.
UPLOAD_DIR=
