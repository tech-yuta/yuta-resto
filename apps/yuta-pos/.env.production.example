DATABASE_URL=postgres://yuta:replace_with_encoded_password@luna-postgres:5432/yuta_resto
POSTGRES_NETWORK=postgres_default
POS_PORT=3003
NEXT_PUBLIC_POS_URL=https://pos.example.com

# Optional external endpoint used only to distinguish Internet loss from a
# healthy local POS. Leave empty to report local service health only.
POS_INTERNET_CHECK_URL=

PRINT_WORKER_OUTPUT_DIR=/app/.tmp/prints
PRINT_OUTPUT_DIR=./.tmp/prints
PRINT_WORKER_BATCH_SIZE=10
PRINT_WORKER_INTERVAL_MS=3000
PRINT_WORKER_FAIL_RATE=0

# Host-side backup scripts. Use an absolute directory outside the database
# disk in production.
POS_BACKUP_DIR=/srv/backups/yuta-pos
POS_BACKUP_RETENTION_DAYS=14
